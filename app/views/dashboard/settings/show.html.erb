<% content_for :title, "Settings" %>

<div class="max-w-xl mx-auto space-y-6">
  <h1 class="text-2xl font-bold text-on-surface">Settings</h1>

  <div class="m3-card divide-y divide-outline-variant overflow-hidden">
    <div class="px-5 py-4">
      <p class="m3-label">Name</p>
      <p class="text-sm text-on-surface"><%= current_user.full_name %></p>
    </div>
    <div class="px-5 py-4">
      <p class="m3-label">Email</p>
      <p class="text-sm text-on-surface"><%= current_user.email %></p>
    </div>
    <div class="px-5 py-4">
      <p class="m3-label">User ID</p>
      <code class="text-xs bg-surface-container-high px-2 py-1 rounded font-mono text-on-surface"><%= current_user.public_id %></code>
    </div>
  </div>

  <div class="m3-card divide-y divide-outline-variant overflow-hidden">
    <%= link_to dashboard_connected_accounts_path, class: "flex items-center justify-between px-5 py-4 hover:bg-surface-container-high transition-colors" do %>
      <p class="text-sm text-on-surface">Connected Google accounts</p>
      <svg class="w-4 h-4 text-on-surface-variant" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
    <%= link_to dashboard_notifications_path, class: "flex items-center justify-between px-5 py-4 hover:bg-surface-container-high transition-colors" do %>
      <p class="text-sm text-on-surface">Notification settings</p>
      <svg class="w-4 h-4 text-on-surface-variant" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
    <%= link_to dashboard_ics_feed_path, class: "flex items-center justify-between px-5 py-4 hover:bg-surface-container-high transition-colors" do %>
      <p class="text-sm text-on-surface">ICS calendar feed</p>
      <svg class="w-4 h-4 text-on-surface-variant" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
  </div>

  <div>
    <%= link_to destroy_user_session_path,
        data: { turbo_method: :delete },
        class: "m3-btn-outlined w-full justify-center" do %>
      Sign out
    <% end %>
  </div>
</div>

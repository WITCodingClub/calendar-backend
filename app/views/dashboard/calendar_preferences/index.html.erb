<% content_for :title, "Preferences" %>

<div class="max-w-2xl mx-auto space-y-6">
  <h1 class="text-2xl font-bold text-on-surface">Calendar Preferences</h1>

  <!-- Global preferences -->
  <div class="m3-card overflow-hidden">
    <div class="px-5 py-4 border-b border-outline-variant">
      <h2 class="text-base font-semibold text-on-surface">Global Defaults</h2>
      <p class="text-xs text-on-surface-variant mt-0.5">Applied to all events unless overridden per event type.</p>
    </div>
    <div class="px-5 py-4">
      <%= form_with url: dashboard_calendar_preference_path("global"), method: :patch, class: "space-y-4" do |f| %>
        <div>
          <label class="m3-label">Event title template</label>
          <%= f.text_field :title_template,
              name: "calendar_preference[title_template]",
              value: @global_pref.title_template,
              placeholder: "{{subject}} {{course_number}} — {{title}}",
              class: "m3-input" %>
        </div>
        <div>
          <label class="m3-label">Description template</label>
          <%= f.text_area :description_template,
              name: "calendar_preference[description_template]",
              value: @global_pref.description_template,
              rows: 3,
              class: "m3-input" %>
        </div>
        <div>
          <label class="m3-label">Location template</label>
          <%= f.text_field :location_template,
              name: "calendar_preference[location_template]",
              value: @global_pref.location_template,
              placeholder: "{{building_room}}",
              class: "m3-input" %>
        </div>
        <div class="flex justify-end">
          <%= f.submit "Save", class: "m3-btn-filled" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Per-event-type preferences summary -->
  <% if @event_type_prefs.any? %>
    <div class="m3-card overflow-hidden">
      <div class="px-5 py-4 border-b border-outline-variant">
        <h2 class="text-base font-semibold text-on-surface">Event Type Overrides</h2>
      </div>
      <div class="divide-y divide-outline-variant">
        <% @event_type_prefs.each do |pref| %>
          <div class="px-5 py-3 flex items-center justify-between">
            <span class="text-sm text-on-surface"><%= pref.event_type&.humanize %></span>
            <div class="flex gap-2">
              <%= link_to "Edit",
                  dashboard_calendar_preference_path(pref.event_type),
                  class: "text-xs text-primary hover:underline" %>
              <%= button_to "Reset",
                  dashboard_calendar_preference_path(pref.event_type),
                  method: :patch,
                  params: { calendar_preference: { title_template: nil, description_template: nil, location_template: nil } },
                  class: "text-xs text-on-surface-variant hover:text-error" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calendar Connected</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); }
    .card { background: white; border-radius: 12px; padding: 2rem; text-align: center; max-width: 400px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
    .icon { font-size: 3rem; margin-bottom: 1rem; }
    h1 { color: #1a1a1a; margin: 0 0 0.5rem; font-size: 1.5rem; }
    p { color: #666; margin: 0.25rem 0; font-size: 0.95rem; }
    .email { color: #d13732; font-weight: 600; }
    .closing { margin-top: 1.5rem; color: #999; font-size: 0.85rem; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">✅</div>
    <h1>Calendar Connected</h1>
    <p>Successfully connected <span class="email"><%= @email %></span></p>
    <% if @calendar_id.present? %>
      <p>Calendar: <code><%= @calendar_id %></code></p>
    <% end %>
    <p class="closing">This window will close automatically...</p>
  </div>

  <script>
    if (window.opener) {
      window.opener.postMessage({
        type: 'oauth-success',
        email: '<%= j @email %>',
        calendarId: '<%= j @calendar_id.to_s %>'
      }, '*');
    }
    setTimeout(function() { window.close(); }, 3000);
  </script>
</body>
</html>

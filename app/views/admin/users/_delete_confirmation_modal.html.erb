<% button_text ||= "Delete" %>
<% button_class ||= "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer bg-error-container text-on-error-container" %>

<div data-controller="delete-confirmation"
     data-delete-confirmation-confirm-text-value="<%= user.email %>"
     data-delete-confirmation-item-type-value="user">

  <div data-delete-confirmation-target="modal"
       data-action="click->delete-confirmation#closeOnBackdrop"
       class="hidden fixed inset-0 z-50 overflow-y-auto"
       style="background-color: rgba(0,0,0,0.5);">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
      <div class="inline-block align-bottom bg-surface rounded-xl px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6">
        <div class="sm:flex sm:items-start">
          <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-error-container sm:mx-0 sm:h-10 sm:w-10">
            <svg class="h-6 w-6 text-on-error-container" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left flex-1">
            <h3 class="text-lg leading-6 font-medium text-on-surface">Delete User Account</h3>
            <div class="mt-2">
              <p class="text-sm text-on-surface-variant mb-3">You are about to permanently delete:</p>
              <p class="text-sm font-bold text-on-surface mb-3 p-2 bg-surface-container-high rounded"><%= user.email %></p>
              <p class="text-sm text-on-error-container font-semibold mb-3">This action will delete all enrollments, OAuth credentials, and calendar integrations.</p>
              <p class="text-sm text-on-error-container font-bold mb-4">This action cannot be undone.</p>
              <div class="mb-2">
                <label class="block text-sm font-medium text-on-surface-variant mb-2">
                  Type <code class="bg-surface-container-high px-1 py-0.5 rounded text-xs"><%= user.email %></code> to confirm:
                </label>
                <%= text_field_tag "confirm_email", nil,
                    data: {
                      delete_confirmation_target: "input",
                      action: "input->delete-confirmation#checkInput"
                    },
                    placeholder: "Type email to confirm",
                    autocomplete: "off",
                    class: "w-full px-3 py-2 border border-outline-variant rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary text-sm" %>
              </div>
              <div data-delete-confirmation-target="errorMessage" class="hidden text-sm text-on-error-container mt-2 p-2 bg-error-container rounded"></div>
            </div>
          </div>
        </div>
        <div class="mt-5 sm:mt-4 sm:flex sm:flex-row-reverse gap-2">
          <%= button_tag "Delete User",
              type: "button",
              data: { delete_confirmation_target: "confirmButton", action: "click->delete-confirmation#confirm" },
              disabled: true,
              class: "w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-error-container text-base font-medium text-on-error-container hover:opacity-90 sm:ml-3 sm:w-auto sm:text-sm opacity-50 cursor-not-allowed" %>
          <%= button_tag "Cancel",
              type: "button",
              data: { action: "click->delete-confirmation#hide" },
              class: "mt-3 w-full inline-flex justify-center rounded-md border border-outline-variant shadow-sm px-4 py-2 bg-surface text-base font-medium text-on-surface-variant hover:bg-surface-container sm:mt-0 sm:w-auto sm:text-sm cursor-pointer" %>
        </div>
      </div>
    </div>
  </div>

  <%= form_with(url: admin_user_path(user), method: :delete, data: { turbo_frame: "_top" }) do |f| %>
  <% end %>

  <%= button_tag button_text,
      type: "button",
      data: { action: "click->delete-confirmation#show" },
      class: button_class %>
</div>

<div class="m3-card shadow-sm rounded-xl overflow-hidden" data-controller="schedule-collapse">
  <div class="px-4 py-3">
    <div class="flex justify-between items-center mb-3">
      <button type="button" class="flex items-center gap-2 text-lg font-bold hover:text-primary transition-colors" data-action="click->schedule-collapse#toggle">
        <span data-schedule-collapse-target="chevron" class="transform transition-transform" style="transform: rotate(-90deg);">▼</span>
        <span>Weekly Schedule</span>
      </button>
      <% if terms.size > 1 %>
        <select class="px-3 py-1 text-sm border border-outline-variant rounded-md shadow-sm bg-surface text-primary"
                data-action="change->schedule-collapse#switchTerm"
                data-schedule-collapse-target="termSelect">
          <% terms.each_with_index do |term, index| %>
            <option value="<%= term.id %>" <%= index == 0 ? 'selected' : '' %>><%= term.name %></option>
          <% end %>
        </select>
      <% end %>
    </div>

    <div data-schedule-collapse-target="content" style="display: none;">
      <% terms.each_with_index do |term, index| %>
        <div class="<%= index > 0 ? 'hidden' : '' %>" data-term-id="<%= term.id %>" data-schedule-collapse-target="termSchedule">
          <% enrollments = enrollments_by_term[term] || [] %>
          <% if enrollments.any? %>
            <%
              days = %w[Sun Mon Tue Wed Thu Fri Sat]
              time_slots = (8..20).map { |h| "#{h}:00" }
              schedule = Hash.new { |h, k| h[k] = [] }

              enrollments.each do |enrollment|
                next unless enrollment.course
                enrollment.course.meeting_times.each do |mt|
                  next unless mt.day_of_week.present?
                  day_index = Course::MeetingTime.day_of_weeks[mt.day_of_week]
                  start_hour = mt.begin_time / 100
                  end_hour   = (mt.end_time / 100.0).ceil
                  current_date = Date.current
                  is_active = current_date >= mt.start_date.to_date && current_date <= mt.end_date.to_date
                  schedule[day_index] << {
                    meeting_time: mt,
                    course: enrollment.course,
                    start_hour: start_hour,
                    end_hour: end_hour,
                    duration: end_hour - start_hour,
                    active: is_active
                  }
                end
              end
            %>
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse">
                <thead>
                  <tr>
                    <th class="border border-outline-variant bg-surface-container px-1 py-1 text-xs font-medium text-on-surface-variant w-12">Time</th>
                    <% days.each do |day| %>
                      <th class="border border-outline-variant bg-surface-container px-1 py-1 text-xs font-medium text-on-surface-variant min-w-[100px]"><%= day %></th>
                    <% end %>
                  </tr>
                </thead>
                <tbody>
                  <% time_slots.each_with_index do |time, slot_index| %>
                    <tr>
                      <td class="border border-outline-variant bg-surface-container px-1 py-0.5 text-xs font-medium text-on-surface-variant whitespace-nowrap"><%= time %></td>
                      <% days.each_with_index do |day, day_index| %>
                        <td class="border border-outline-variant p-0 relative h-12">
                          <%
                            current_hour = slot_index + 8
                            day_schedule = schedule[day_index].select { |item| item[:start_hour] <= current_hour && current_hour < item[:end_hour] }
                          %>
                          <% day_schedule.each do |item| %>
                            <% if item[:start_hour] == current_hour %>
                              <%
                                bg_class   = item[:active] ? "bg-primary-container border-primary" : "bg-surface-container-high border-outline-variant"
                                text_class = item[:active] ? "text-primary" : "text-on-surface-variant"
                              %>
                              <div class="absolute inset-x-0 top-0 <%= bg_class %> border rounded p-0.5 m-0.5 overflow-hidden"
                                   style="height: <%= item[:duration] * 100 %>%; z-index: 10;">
                                <div class="text-xs font-semibold <%= text_class %> truncate">
                                  <%= item[:course].subject %> <%= item[:course].course_number %>
                                </div>
                                <% if item[:meeting_time].building_room.present? %>
                                  <div class="text-xs text-on-surface-variant truncate"><%= item[:meeting_time].building_room %></div>
                                <% end %>
                              </div>
                            <% end %>
                          <% end %>
                        </td>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <div class="mt-4 text-sm text-on-surface-variant">
              <h3 class="font-semibold mb-2">Course Details:</h3>
              <div class="space-y-2">
                <% enrollments.each do |enrollment| %>
                  <div class="border-l-4 border-primary pl-3 py-1">
                    <div class="font-medium text-on-surface">
                      <%= enrollment.course.subject %> <%= enrollment.course.course_number %>: <%= enrollment.course.title %>
                    </div>
                    <% if enrollment.course.faculties.any? %>
                      <div class="text-xs text-on-surface-variant">Instructor(s): <%= enrollment.course.faculties.map(&:display_name).join(", ") %></div>
                    <% end %>
                    <% unique_locations = enrollment.course.meeting_times.map(&:building_room).compact.uniq %>
                    <% if unique_locations.any? %>
                      <div class="text-xs text-on-surface-variant">Location(s): <%= unique_locations.join(", ") %></div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% else %>
            <p class="text-on-surface-variant">No courses found for <%= term.name %>.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

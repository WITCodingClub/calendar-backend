<%= turbo_frame_tag "users_table" do %>
  <div class="m3-card shadow-sm rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-outline-variant">
        <thead class="bg-surface-container-high">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Email</th>
            <% if policy(User).view_access_level? %>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Access Level</th>
            <% end %>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Created</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-on-surface-variant uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
          <% @users.each do |user| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-on-surface font-medium"><%= user.email %></div>
              </td>
              <% if policy(User).view_access_level? %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-primary-container text-primary">
                    <%= user.access_level_text %>
                  </span>
                </td>
              <% end %>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface">
                <%= user.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <% if policy(user).show? %>
                  <%= link_to "View", admin_user_path(user), data: { turbo_frame: "_top" }, class: "text-sm font-medium text-primary hover:underline" %>
                <% end %>
                <% if policy(user).edit? %>
                  <%= link_to "Edit", edit_admin_user_path(user), data: { turbo_frame: "_top" }, class: "ml-3 text-sm font-medium text-primary hover:underline" %>
                <% end %>
                <% if policy(user).destroy? %>
                  <span class="ml-3 inline-block">
                    <%= render "delete_confirmation_modal",
                        user: user,
                        button_text: "Delete",
                        button_class: "text-sm font-medium text-primary hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
                  </span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @users.respond_to?(:total_pages) %>
      <div class="px-6 py-4 border-t border-outline-variant bg-surface-container-low">
        <%= paginate @users %>
      </div>
    <% end %>
  </div>
<% end %>

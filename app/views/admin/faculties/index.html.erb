<div class="container mx-auto px-2 pb-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Faculty & Staff</h1>
    <div class="flex gap-2">
      <% if policy(Faculty).sync_directory? %>
        <%= button_to "Sync Directory", sync_directory_admin_faculties_path,
            method: :post,
            class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm cursor-pointer",
            form: { class: "inline-flex" },
            data: { turbo_confirm: "This will sync all 800+ faculty/staff from the WIT directory. Continue?" } %>
      <% end %>
      <%= link_to "Directory Status", directory_status_admin_faculties_path, class: "glass-button px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
      <%= link_to "Missing RMP IDs", missing_rmp_ids_admin_faculties_path, class: "glass-button px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
      <%= link_to "Back to Dashboard", admin_root_path, class: "glass-button px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
    </div>
  </div>

  <div class="mb-4">
    <%= form_with(url: admin_faculties_path, method: :get, class: "flex gap-2") do |f| %>
      <%= f.text_field :search,
          value: params[:search],
          placeholder: "Search by name, email, or department...",
          class: "glass-input flex-1 px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-opacity-50",
          autofocus: params[:search].present? %>
      <%= f.submit "Search", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded cursor-pointer" %>
      <% if params[:search].present? %>
        <%= link_to "Clear", admin_faculties_path, class: "glass-button px-6 py-2 rounded inline-flex items-center" %>
      <% end %>
    <% end %>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
    <div class="glass-card p-4 rounded-lg text-center">
      <p class="text-2xl font-bold text-[#d13732]"><%= Faculty.count %></p>
      <p class="text-xs text-gray-600 uppercase">Total</p>
    </div>
    <div class="glass-card p-4 rounded-lg text-center">
      <p class="text-2xl font-bold text-[#d13732]"><%= Faculty.faculty_only.count %></p>
      <p class="text-xs text-gray-600 uppercase">Faculty</p>
    </div>
    <div class="glass-card p-4 rounded-lg text-center">
      <p class="text-2xl font-bold text-[#d13732]"><%= Faculty.staff_only.count %></p>
      <p class="text-xs text-gray-600 uppercase">Staff</p>
    </div>
    <div class="glass-card p-4 rounded-lg text-center">
      <p class="text-2xl font-bold text-[#d13732]"><%= Faculty.where.not(directory_last_synced_at: nil).count %></p>
      <p class="text-xs text-gray-600 uppercase">Synced</p>
    </div>
  </div>

  <div class="glass-card shadow-lg rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-white/50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Name</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Title</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Department</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Email</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Type</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white/30">
          <% @faculties.each do |faculty| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <% if faculty.photo_url.present? %>
                    <img src="<%= faculty.photo_url %>" alt="" class="h-10 w-10 rounded-full object-cover mr-3">
                  <% else %>
                    <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center mr-3">
                      <span class="text-gray-600 text-sm font-medium"><%= faculty.initials %></span>
                    </div>
                  <% end %>
                  <div>
                    <div class="text-sm font-medium">
                      <%= link_to faculty.full_name, admin_faculty_path(faculty), class: "text-[#d13732] hover:underline" %>
                    </div>
                    <% if faculty.office_location.present? %>
                      <div class="text-xs text-gray-500"><%= faculty.office_location %></div>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= faculty.title || "—" %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= faculty.department || faculty.school || "—" %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                <%= mail_to faculty.email, faculty.email, class: "hover:underline text-blue-600" if faculty.email %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% case faculty.employee_type %>
                <% when "faculty" %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800">Faculty</span>
                <% when "staff" %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-800">Staff</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800">Unknown</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @faculties.respond_to?(:total_pages) %>
      <div class="px-6 py-4 border-t border-gray-200 bg-white/40">
        <%= paginate @faculties %>
      </div>
    <% end %>
  </div>
</div>

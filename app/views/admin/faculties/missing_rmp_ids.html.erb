<div class="container mx-auto px-2 pb-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-on-surface">Professors Missing RMP IDs</h1>
    <div class="flex gap-2">
      <%= link_to "All Faculty", admin_faculties_path, class: "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
      <%= link_to "Back to Dashboard", admin_root_path, class: "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
    </div>
  </div>

  <div class="mb-4">
    <%= form_with(url: missing_rmp_ids_admin_faculties_path, method: :get, class: "flex gap-2") do |f| %>
      <%= f.text_field :search,
          value: params[:search],
          placeholder: "Search by name...",
          class: "m3-input flex-1 px-4 py-2 border border-outline-variant rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-opacity-50" %>
      <% if params[:search].present? %>
        <%= link_to "Clear", missing_rmp_ids_admin_faculties_path, class: "m3-btn-outlined px-6 py-2 rounded inline-flex items-center" %>
      <% end %>
    <% end %>
  </div>

  <% if @faculties.empty? %>
    <div class="m3-card shadow-sm rounded-xl p-8 text-center">
      <div class="text-on-tertiary-container text-lg font-semibold mb-2">All professors have RMP IDs assigned!</div>
      <p class="text-on-surface-variant">All professors with courses have Rate My Professor IDs.</p>
    </div>
  <% else %>
    <div class="m3-card shadow-sm rounded-xl mb-4 p-4">
      <div class="flex justify-between items-center">
        <p class="text-on-surface">
          <span class="font-bold text-lg"><%= @faculties.total_count %></span> professors (with courses) are missing RMP IDs
        </p>
        <% if policy(Faculty).batch_auto_fill? %>
          <%= button_to "Auto-Fill All",
              batch_auto_fill_admin_faculties_path,
              method: :post,
              class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm cursor-pointer",
              form: { class: "inline-flex" },
              data: { turbo_confirm: "This will queue background jobs to search Rate My Professor for all #{@faculties.total_count} faculty members. Continue?" } %>
        <% end %>
      </div>
    </div>

    <div class="m3-card shadow-sm rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-outline-variant">
          <thead class="bg-surface-container-high">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Name</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Email</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Courses</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant">
            <% @faculties.each do |faculty| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-on-surface font-medium">
                    <%= link_to faculty.full_name, admin_faculty_path(faculty), class: "text-primary hover:underline" %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface"><%= faculty.email || "N/A" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface"><%= faculty.courses.count %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <div class="flex gap-2 flex-wrap">
                    <% if policy(faculty).auto_fill_rmp_id? %>
                      <%= button_to "Auto Search",
                          auto_fill_rmp_id_admin_faculty_path(faculty),
                          method: :post,
                          class: "bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-xs cursor-pointer",
                          form: { class: "inline-flex" } %>
                    <% end %>
                    <% if policy(faculty).search_rmp? %>
                      <%= link_to "Manual Search", search_rmp_admin_faculty_path(faculty),
                          class: "m3-btn-outlined px-3 py-1 rounded text-xs cursor-pointer inline-block" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @faculties.respond_to?(:total_pages) %>
        <div class="px-6 py-4 border-t border-outline-variant bg-surface-container-low">
          <%= paginate @faculties %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

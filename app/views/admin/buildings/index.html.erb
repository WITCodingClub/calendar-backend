<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Admin", admin_root_path, class: "text-sm font-medium text-primary hover:underline" %>
  </div>

  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold mb-1 text-on-surface">Buildings</h1>
      <p class="text-on-surface-variant">Compare LeopardWeb building names against 25Live formal names and resolve discrepancies.</p>
    </div>
    <div class="flex gap-2">
      <%= button_to "Sync 25Live Spaces", sync_admin_buildings_path,
          method: :post,
          class: "m3-btn-outlined px-4 py-2 rounded text-sm",
          data: { turbo_confirm: "Queue a 25Live space sync? This will run in the background." } %>
      <% if policy(Building).apply_all? %>
        <% mismatched_count = @buildings.count { |b| b.formal_name.present? && b.name != b.formal_name } %>
        <%= button_to "Apply All 25Live Names (#{mismatched_count})",
            apply_all_admin_buildings_path,
            method: :post,
            class: "px-4 py-2 rounded text-sm bg-green-600 hover:bg-green-700 text-white disabled:opacity-50",
            disabled: mismatched_count.zero?,
            data: { turbo_confirm: "Apply 25Live formal names to all #{mismatched_count} mismatched building(s)?" } %>
      <% end %>
    </div>
  </div>

  <%# Summary stats %>
  <% total          = @buildings.count %>
  <% synced         = @buildings.count { |b| b.formal_name.present? } %>
  <% mismatched     = @buildings.count { |b| b.formal_name.present? && b.name != b.formal_name } %>
  <% unsynced       = total - synced %>

  <div class="grid grid-cols-4 gap-4 mb-6">
    <div class="m3-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-on-surface"><%= total %></div>
      <div class="text-xs text-on-surface-variant uppercase tracking-wider mt-1">Total Buildings</div>
    </div>
    <div class="m3-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-on-tertiary-container"><%= synced %></div>
      <div class="text-xs text-on-surface-variant uppercase tracking-wider mt-1">Have 25Live Name</div>
    </div>
    <div class="m3-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold <%= mismatched > 0 ? "text-on-secondary-container" : "text-on-surface-variant" %>"><%= mismatched %></div>
      <div class="text-xs text-on-surface-variant uppercase tracking-wider mt-1">Name Mismatch</div>
    </div>
    <div class="m3-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-on-surface-variant"><%= unsynced %></div>
      <div class="text-xs text-on-surface-variant uppercase tracking-wider mt-1">Not in 25Live</div>
    </div>
  </div>

  <div class="m3-card shadow-sm rounded-xl overflow-hidden">
    <table class="min-w-full divide-y divide-outline-variant">
      <thead class="bg-surface-container-high">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Code</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Current Name (LeopardWeb)</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Formal Name (25Live)</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Rooms</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-outline-variant">
        <% @buildings.each do |building| %>
          <%
            status =
              if building.formal_name.blank?
                :no_25live
              elsif building.name == building.formal_name
                :match
              else
                :mismatch
              end
          %>
          <tr class="hover:bg-surface-container <%= "bg-secondary-container/20" if status == :mismatch %>">
            <td class="px-4 py-3 whitespace-nowrap">
              <code class="text-sm bg-surface-container-high px-2 py-1 rounded"><%= building.abbreviation %></code>
            </td>
            <td class="px-4 py-3">
              <span class="<%= "font-medium text-on-secondary-container" if status == :mismatch %>">
                <%= building.name %>
              </span>
            </td>
            <td class="px-4 py-3">
              <% if building.formal_name.present? %>
                <span class="<%= "font-medium text-on-tertiary-container" if status == :mismatch %>">
                  <%= building.formal_name %>
                </span>
              <% else %>
                <span class="text-on-surface-variant italic text-sm">Not synced</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-on-surface-variant">
              <%= building.rooms.size %>
            </td>
            <td class="px-4 py-3 whitespace-nowrap">
              <% case status %>
              <% when :match %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-tertiary-container text-on-tertiary-container">Matches</span>
              <% when :mismatch %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary-container text-on-secondary-container">Mismatch</span>
              <% when :no_25live %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-container-high text-on-surface-variant">No 25Live data</span>
              <% end %>
            </td>
            <td class="px-4 py-3 whitespace-nowrap">
              <% if status == :mismatch %>
                <%= button_to "Apply 25Live Name",
                    apply_formal_name_admin_building_path(building),
                    method: :post,
                    class: "m3-btn-outlined px-3 py-1.5 rounded text-xs",
                    data: { turbo_confirm: "Update \"#{building.abbreviation}\" name from \"#{building.name}\" to \"#{building.formal_name}\"?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-6 p-4 rounded-xl bg-tertiary-container border border-outline-variant">
    <p class="text-sm text-on-tertiary-container">
      <strong>How it works:</strong>
      When you run a sync, we fetch all spaces from the 25Live API and populate the <em>Formal Name</em> field using the 25Live building name.
      Applying a 25Live name updates the building's display name used in Google Calendar event locations.
    </p>
  </div>
</div>

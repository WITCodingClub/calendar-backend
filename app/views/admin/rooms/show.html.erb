<div class="container mx-auto px-2 pb-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-on-surface">Room <%= @room.number %></h1>
      <p class="text-sm text-on-surface-variant"><%= @room.building.name %> (<%= @room.building.abbreviation %>)</p>
    </div>
    <%= link_to "← Back to Rooms", admin_rooms_path, class: "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
  </div>

  <% if @courses_by_term.any? %>
    <% @courses_by_term.each do |term, courses| %>
      <div class="mb-6">
        <h2 class="text-base font-semibold mb-3 text-on-surface-variant uppercase tracking-wider"><%= term.name %></h2>
        <div class="m3-card shadow-sm rounded-xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-outline-variant">
              <thead class="bg-surface-container-high">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Course</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Instructor</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Meeting Times</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-outline-variant">
                <% courses.each do |course| %>
                  <tr class="hover:bg-surface-container-low transition">
                    <td class="px-6 py-4">
                      <div class="text-sm font-medium text-on-surface"><%= course.title %></div>
                      <div class="text-xs text-on-surface-variant"><%= course.crn %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface">
                      <%= course.faculties.map(&:full_name).join(", ").presence || "TBA" %>
                    </td>
                    <td class="px-6 py-4 text-sm text-on-surface-variant">
                      <% course.meeting_times.select { |mt| mt.rooms.any? { |r| r.id == @room.id } }.each do |mt| %>
                        <div class="text-xs"><%= mt.day_of_week&.capitalize %>: <%= mt.formatted_time_range %></div>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <p class="text-on-surface-variant">No courses scheduled in this room.</p>
  <% end %>
</div>

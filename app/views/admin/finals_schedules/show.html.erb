<%= turbo_frame_tag "finals_schedule_#{@finals_schedule.id}",
    data: (@finals_schedule.pending? || @finals_schedule.processing?) ?
      { controller: "auto-refresh", "auto-refresh-interval-value": 3000 } : {} do %>

<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Finals Schedules", admin_finals_schedules_path,
        class: "text-sm font-medium text-primary hover:underline", data: { turbo_frame: "_top" } %>
  </div>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-on-surface">Finals Schedule: <%= @finals_schedule.term.name %></h1>
    <% if policy(@finals_schedule).destroy? %>
      <%= button_to "Delete Schedule", admin_finals_schedule_path(@finals_schedule),
          method: :delete,
          data: { turbo_confirm: "Delete this finals schedule? This will NOT delete the associated final exams." },
          class: "m3-btn-outlined px-6 py-2 rounded inline-flex items-center bg-error-container text-on-error-container hover:opacity-90" %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div class="m3-card shadow-sm rounded-xl overflow-hidden">
      <div class="px-6 py-4 bg-surface-container-high border-b border-outline-variant">
        <h2 class="text-lg font-semibold text-on-surface">Upload Details</h2>
      </div>
      <div class="px-6 py-4">
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">Status</dt>
            <dd class="mt-1"><%= render "status_badge", status: @finals_schedule.status %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">Uploaded By</dt>
            <dd class="mt-1 text-sm text-on-surface"><%= @finals_schedule.uploaded_by.email %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">Uploaded At</dt>
            <dd class="mt-1 text-sm text-on-surface"><%= @finals_schedule.created_at.strftime("%B %d, %Y at %l:%M %p") %></dd>
          </div>
          <% if @finals_schedule.processed_at %>
            <div>
              <dt class="text-sm font-medium text-on-surface-variant">Processed At</dt>
              <dd class="mt-1 text-sm text-on-surface"><%= @finals_schedule.processed_at.strftime("%B %d, %Y at %l:%M %p") %></dd>
            </div>
          <% end %>
          <% if @finals_schedule.pdf_file.attached? %>
            <div>
              <dt class="text-sm font-medium text-on-surface-variant">PDF File</dt>
              <dd class="mt-1">
                <%= link_to "Download PDF", rails_blob_path(@finals_schedule.pdf_file, disposition: "attachment"),
                    class: "text-sm text-primary hover:underline" %>
                <span class="text-xs text-on-surface-variant ml-2">
                  (<%= number_to_human_size(@finals_schedule.pdf_file.blob.byte_size) %>)
                </span>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <div class="m3-card shadow-sm rounded-xl overflow-hidden">
      <div class="px-6 py-4 bg-surface-container-high border-b border-outline-variant">
        <h2 class="text-lg font-semibold text-on-surface">Processing Results</h2>
      </div>
      <div class="px-6 py-4">
        <% if @finals_schedule.stats.present? %>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-tertiary-container rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-on-tertiary-container"><%= @finals_schedule.stats["created"] || 0 %></div>
              <div class="text-sm text-on-tertiary-container">Finals Created</div>
            </div>
            <div class="bg-tertiary-container rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-on-tertiary-container"><%= @finals_schedule.stats["updated"] || 0 %></div>
              <div class="text-sm text-on-tertiary-container">Finals Updated</div>
            </div>
            <div class="bg-tertiary-container rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-on-tertiary-container"><%= @final_exams.count(&:linked?) %></div>
              <div class="text-sm text-on-tertiary-container">Linked to Courses</div>
            </div>
            <div class="bg-secondary-container rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-on-secondary-container"><%= @final_exams.count(&:orphan?) %></div>
              <div class="text-sm text-on-secondary-container">Awaiting Courses</div>
            </div>
            <div class="bg-surface-container rounded-xl p-4 text-center col-span-2">
              <div class="text-2xl font-bold text-on-surface"><%= @finals_schedule.stats["total"] || 0 %></div>
              <div class="text-sm text-on-surface-variant">Total Parsed</div>
            </div>
          </div>
        <% elsif @finals_schedule.pending? || @finals_schedule.processing? %>
          <p class="text-sm text-on-surface-variant">Processing in progress...</p>
        <% else %>
          <p class="text-sm text-on-surface-variant">No statistics available.</p>
        <% end %>
      </div>
    </div>
  </div>

  <% if @finals_schedule.error_message.present? %>
    <div class="m3-card shadow-sm rounded-xl overflow-hidden mb-6">
      <div class="px-6 py-4 bg-error-container border-b border-error flex justify-between items-center">
        <h2 class="text-lg font-semibold text-on-error-container">Errors & Warnings</h2>
        <span class="text-sm text-on-error-container"><%= @finals_schedule.error_message.lines.count %> messages</span>
      </div>
      <div class="px-6 py-4 bg-error-container max-h-64 overflow-y-auto">
        <pre class="text-sm text-on-error-container whitespace-pre-wrap font-mono"><%= @finals_schedule.error_message %></pre>
      </div>
    </div>
  <% end %>

  <div class="m3-card shadow-sm rounded-xl overflow-hidden">
    <div class="px-6 py-4 bg-surface-container-high border-b border-outline-variant flex justify-between items-center">
      <h2 class="text-lg font-semibold text-on-surface">Final Exams for <%= @finals_schedule.term.name %></h2>
      <span class="text-sm text-on-surface-variant"><%= @final_exams.count %> exams</span>
    </div>
    <div class="max-h-[32rem] overflow-y-auto">
      <table class="min-w-full divide-y divide-outline-variant">
        <thead class="bg-surface-container-high sticky top-0">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">CRN</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Course</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Date</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Time</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Location</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
          <% if @final_exams.any? %>
            <% @final_exams.each do |exam| %>
              <tr class="<%= 'bg-secondary-container/30' if exam.orphan? %>">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface font-mono">
                  <%= exam.crn %>
                  <% if exam.orphan? %>
                    <span class="ml-1 text-xs text-on-secondary-container" title="No course found for this CRN yet">⏳</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if exam.linked? %>
                    <div class="text-sm font-medium text-on-surface">
                      <%= exam.course.subject %>-<%= exam.course.course_number %>-<%= exam.course.section_number %>
                    </div>
                    <div class="text-sm text-on-surface-variant"><%= exam.course.title %></div>
                  <% else %>
                    <div class="text-sm text-on-secondary-container italic">Awaiting course data...</div>
                    <div class="text-xs text-on-surface-variant">Will link when course is imported</div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface">
                  <%= exam.exam_date.strftime("%a, %b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface">
                  <%= exam.formatted_start_time %> - <%= exam.formatted_end_time %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface">
                  <% if exam.respond_to?(:rooms_matched?) && exam.rooms_matched? %>
                    <span title="<%= exam.location %>"><%= exam.location_with_names %></span>
                  <% else %>
                    <%= exam.location.presence || "—" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-sm text-on-surface-variant">
                No final exams found for this term.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<% end %>

<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Finals Schedules", admin_finals_schedules_path, class: "text-sm font-medium text-primary hover:underline" %>
  </div>

  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold mb-6 text-on-surface">Confirm Schedule Update</h1>

    <div class="bg-secondary-container border border-outline-variant rounded-xl p-4 mb-6">
      <h3 class="text-lg font-semibold text-on-secondary-container mb-2">Existing Finals Found</h3>
      <p class="text-sm text-on-secondary-container">
        There are already <strong><%= @existing_exams.count %></strong> final exams recorded for
        <strong><%= @finals_schedule.term&.name %></strong>.
        Processing the new schedule will update any matching CRNs and add new ones.
      </p>
    </div>

    <div class="bg-tertiary-container border border-outline-variant rounded-xl p-4 mb-6">
      <h3 class="text-lg font-semibold text-on-tertiary-container mb-2">Uploaded File</h3>
      <p class="text-sm text-on-tertiary-container">
        <strong><%= @finals_schedule.pdf_file.filename %></strong>
        (<%= number_to_human_size(@finals_schedule.pdf_file.blob.byte_size) %>)
      </p>
    </div>

    <div class="m3-card shadow-sm rounded-xl overflow-hidden mb-6">
      <div class="px-6 py-4 bg-surface-container-high border-b border-outline-variant">
        <h2 class="text-lg font-semibold text-on-surface">Current Final Exams (<%= @existing_exams.count %>)</h2>
      </div>
      <div class="overflow-x-auto max-h-96">
        <table class="min-w-full divide-y divide-outline-variant">
          <thead class="bg-surface-container-high sticky top-0">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">CRN</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Course</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Time</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Location</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant">
            <% @existing_exams.each do |exam| %>
              <tr class="<%= 'bg-secondary-container/30' if exam.orphan? %>">
                <td class="px-6 py-3 whitespace-nowrap text-sm text-on-surface font-mono">
                  <%= exam.crn %>
                  <% if exam.orphan? %>
                    <span class="ml-1 text-xs text-on-secondary-container" title="No course found for this CRN yet">⏳</span>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% if exam.linked? %>
                    <div class="text-sm font-medium text-on-surface">
                      <%= exam.course.subject %>-<%= exam.course.course_number %>-<%= exam.course.section_number %>
                    </div>
                    <div class="text-xs text-on-surface-variant"><%= exam.course.title.truncate(40) %></div>
                  <% else %>
                    <div class="text-sm text-on-secondary-container italic">Awaiting course data</div>
                  <% end %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-on-surface">
                  <%= exam.exam_date.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-on-surface">
                  <%= exam.formatted_start_time %> - <%= exam.formatted_end_time %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-on-surface">
                  <%= exam.location.presence || "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="m3-card shadow-sm rounded-xl overflow-hidden">
      <div class="px-6 py-6">
        <h3 class="text-lg font-semibold mb-4 text-on-surface">What will happen:</h3>
        <ul class="list-disc list-inside text-sm text-on-surface mb-6 space-y-2">
          <li>Final exams with <strong>matching CRNs</strong> will be <span class="text-primary font-medium">updated</span> with new date/time/location</li>
          <li>Final exams for <strong>new CRNs</strong> will be <span class="text-on-tertiary-container font-medium">created</span></li>
          <li>Existing finals for CRNs <strong>not in the new PDF</strong> will be <span class="text-on-surface-variant font-medium">unchanged</span></li>
        </ul>

        <div class="flex gap-3 pt-4">
          <%= button_to "Confirm and Process Schedule",
              process_schedule_admin_finals_schedule_path(@finals_schedule),
              method: :post,
              class: "m3-btn-outlined px-6 py-2 rounded inline-flex items-center bg-secondary-container hover:opacity-90 text-on-secondary-container" %>
          <%= link_to "Cancel",
              admin_finals_schedule_path(@finals_schedule),
              data: { turbo_method: :delete, turbo_confirm: "Cancel upload and delete the pending schedule?" },
              class: "px-6 py-2 rounded inline-flex items-center text-on-surface-variant hover:text-on-surface" %>
        </div>
      </div>
    </div>
  </div>
</div>

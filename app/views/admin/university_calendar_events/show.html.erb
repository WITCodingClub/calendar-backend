<div class="container mx-auto px-2 pb-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-on-surface"><%= truncate(@event.summary, length: 60) %></h1>
    <%= link_to "Back to Events", admin_university_calendar_events_path, class: "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 m3-card shadow-sm rounded-xl overflow-hidden">
      <div class="px-6 py-5">
        <h2 class="text-lg font-semibold mb-4 text-on-surface">Event Details</h2>
        <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">Summary</dt>
            <dd class="mt-1 text-sm text-on-surface"><%= @event.summary %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">Category</dt>
            <dd class="mt-1">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full
                <%= @event.category == 'holiday' ? 'bg-error-container text-on-error-container' : 'bg-surface-container-high text-on-surface' %>">
                <%= @event.category&.titleize || 'Unknown' %>
              </span>
              <% if @event.excludes_classes? %>
                <span class="ml-1 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-secondary-container text-on-secondary-container">No Classes</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">Start Time</dt>
            <dd class="mt-1 text-sm text-on-surface">
              <%= @event.start_time.strftime("%B %d, %Y") %>
              <% unless @event.all_day %>at <%= @event.start_time.strftime("%l:%M %p") %><% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">End Time</dt>
            <dd class="mt-1 text-sm text-on-surface">
              <%= @event.end_time.strftime("%B %d, %Y") %>
              <% unless @event.all_day %>at <%= @event.end_time.strftime("%l:%M %p") %><% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">All Day</dt>
            <dd class="mt-1 text-sm text-on-surface"><%= @event.all_day ? 'Yes' : 'No' %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-on-surface-variant">Location</dt>
            <dd class="mt-1 text-sm text-on-surface"><%= @event.location.presence || "—" %></dd>
          </div>
          <% if @event.description.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-on-surface-variant">Description</dt>
              <dd class="mt-1 text-sm text-on-surface whitespace-pre-wrap"><%= @event.description %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <div class="space-y-6">
      <div class="m3-card shadow-sm rounded-xl overflow-hidden">
        <div class="px-6 py-5">
          <h2 class="text-lg font-semibold mb-4 text-on-surface">Additional Info</h2>
          <dl class="space-y-3">
            <div>
              <dt class="text-sm font-medium text-on-surface-variant">Term</dt>
              <dd class="mt-1 text-sm text-on-surface">
                <% if @event.term %>
                  <%= link_to @event.term.name, admin_term_path(@event.term), class: "text-primary hover:underline" %>
                <% else %>
                  <span class="text-on-surface-variant">Not assigned</span>
                <% end %>
              </dd>
            </div>
            <% if @event.academic_term.present? %>
              <div>
                <dt class="text-sm font-medium text-on-surface-variant">Academic Term (ICS)</dt>
                <dd class="mt-1 text-sm text-on-surface"><%= @event.academic_term %></dd>
              </div>
            <% end %>
            <% if @event.organization.present? %>
              <div>
                <dt class="text-sm font-medium text-on-surface-variant">Organization</dt>
                <dd class="mt-1 text-sm text-on-surface"><%= @event.organization %></dd>
              </div>
            <% end %>
          </dl>
        </div>
      </div>

      <div class="m3-card shadow-sm rounded-xl overflow-hidden">
        <div class="px-6 py-5">
          <h2 class="text-lg font-semibold mb-4 text-on-surface">Sync Info</h2>
          <dl class="space-y-3">
            <div>
              <dt class="text-sm font-medium text-on-surface-variant">ICS UID</dt>
              <dd class="mt-1 text-xs text-on-surface font-mono break-all"><%= @event.ics_uid %></dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-on-surface-variant">Created</dt>
              <dd class="mt-1 text-sm text-on-surface"><%= @event.created_at.strftime("%B %d, %Y at %l:%M %p") %></dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-on-surface-variant">Updated</dt>
              <dd class="mt-1 text-sm text-on-surface"><%= @event.updated_at.strftime("%B %d, %Y at %l:%M %p") %></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

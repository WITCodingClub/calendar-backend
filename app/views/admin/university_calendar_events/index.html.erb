<div class="container mx-auto px-2 pb-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-on-surface">University Calendar Events</h1>
    <div class="flex gap-2">
      <% if policy(UniversityCalendarEvent).sync? %>
        <%= button_to "Sync Now", sync_admin_university_calendar_events_path,
            method: :post,
            class: "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer inline-block",
            data: { turbo_confirm: "This will sync events from the university calendar feed. Continue?" } %>
      <% end %>
      <%= link_to "Back to Dashboard", admin_root_path, class: "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
    </div>
  </div>

  <% if policy(UniversityCalendarEvent).backfill? %>
    <div class="m3-card shadow-sm rounded-xl p-4 mb-6">
      <h2 class="text-base font-semibold mb-3 text-on-surface">Backfill Historical Events</h2>
      <%= form_with(url: backfill_admin_university_calendar_events_path, method: :post, class: "flex flex-wrap gap-3 items-end") do |f| %>
        <div>
          <%= f.label :start_date, "Start Date", class: "block text-xs text-on-surface-variant mb-1" %>
          <%= f.date_field :start_date, required: true, class: "m3-input px-3 py-2 border border-outline-variant rounded-md text-sm" %>
        </div>
        <div>
          <%= f.label :end_date, "End Date", class: "block text-xs text-on-surface-variant mb-1" %>
          <%= f.date_field :end_date, required: true, class: "m3-input px-3 py-2 border border-outline-variant rounded-md text-sm" %>
        </div>
        <%= f.submit "Queue Backfill", class: "m3-btn-outlined px-4 py-2 rounded text-sm cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="m3-card p-4 rounded-xl text-center">
      <div class="text-3xl font-bold text-on-surface"><%= @stats[:total] %></div>
      <div class="text-sm text-on-surface-variant">Total Events</div>
    </div>
    <div class="m3-card p-4 rounded-xl text-center">
      <div class="text-3xl font-bold text-on-surface"><%= @stats[:holidays] %></div>
      <div class="text-sm text-on-surface-variant">Holidays</div>
    </div>
    <div class="m3-card p-4 rounded-xl text-center">
      <div class="text-3xl font-bold text-on-surface"><%= @stats[:upcoming] %></div>
      <div class="text-sm text-on-surface-variant">Upcoming</div>
    </div>
    <div class="m3-card p-4 rounded-xl text-center">
      <div class="text-3xl font-bold text-on-surface"><%= @stats[:categories].keys.count %></div>
      <div class="text-sm text-on-surface-variant">Categories</div>
    </div>
  </div>

  <div class="mb-4">
    <%= form_with(url: admin_university_calendar_events_path, method: :get, class: "flex gap-2 flex-wrap") do |f| %>
      <%= f.text_field :search,
          value: params[:search],
          placeholder: "Search events...",
          class: "m3-input flex-1 min-w-[200px] px-4 py-2 border border-outline-variant rounded-md" %>
      <%= f.select :category,
          options_for_select(
            [["All Categories", ""]] + UniversityCalendarEvent::CATEGORIES.map { |c| [c.titleize, c] },
            params[:category]
          ),
          {},
          class: "m3-input px-4 py-2 border border-outline-variant rounded-md" %>
      <label class="flex items-center gap-2 text-sm text-on-surface-variant">
        <%= f.check_box :show_all, { checked: params[:show_all] == "1" }, "1", "0" %>
        Show without location
      </label>
      <%= f.submit "Filter", class: "m3-btn-outlined px-6 py-2 rounded cursor-pointer" %>
      <% if params[:search].present? || params[:category].present? || params[:show_all] == "1" %>
        <%= link_to "Clear", admin_university_calendar_events_path, class: "m3-btn-outlined px-6 py-2 rounded" %>
      <% end %>
    <% end %>
  </div>

  <div class="m3-card shadow-sm rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-outline-variant">
        <thead class="bg-surface-container-high">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Summary</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Category</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Date/Time</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Term</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
          <% @university_calendar_events.each do |event| %>
            <tr class="<%= event.start_time < Time.current ? 'opacity-50' : '' %>">
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-on-surface"><%= truncate(event.summary, length: 80) %></div>
                <% if event.location.present? %>
                  <div class="text-xs text-on-surface-variant"><%= truncate(event.location, length: 40) %></div>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  badge_class = case event.category
                  when 'holiday'      then 'bg-error-container text-on-error-container'
                  when 'term_dates'   then 'bg-tertiary-container text-on-tertiary-container'
                  when 'registration' then 'bg-tertiary-container text-on-tertiary-container'
                  when 'deadline'     then 'bg-secondary-container text-on-secondary-container'
                  when 'study_day'    then 'bg-secondary-container text-on-secondary-container'
                  when 'finals'       then 'bg-surface-container-high text-on-surface'
                  when 'graduation'   then 'bg-surface-container-high text-on-surface'
                  when 'academic'     then 'bg-tertiary-container text-on-tertiary-container'
                  when 'campus_event' then 'bg-tertiary-container text-on-tertiary-container'
                  else 'bg-surface-container-high text-on-surface'
                  end
                %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= badge_class %>">
                  <%= event.category&.titleize || 'Unknown' %>
                </span>
                <% if event.excludes_classes? %>
                  <span class="ml-1 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-secondary-container text-on-secondary-container">No Classes</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface">
                <div><%= event.start_time.strftime("%b %d, %Y") %></div>
                <% if event.all_day %>
                  <div class="text-xs text-on-surface-variant">All Day</div>
                <% else %>
                  <div class="text-xs text-on-surface-variant">
                    <%= event.start_time.strftime("%l:%M %p") %> – <%= event.end_time.strftime("%l:%M %p") %>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-on-surface">
                <%= event.term&.name || event.academic_term.presence || "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= link_to "View", admin_university_calendar_event_path(event), class: "text-primary hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @university_calendar_events.respond_to?(:total_pages) %>
      <div class="px-6 py-4 border-t border-outline-variant bg-surface-container-low">
        <%= paginate @university_calendar_events %>
      </div>
    <% end %>
  </div>

  <div class="mt-6">
    <h2 class="text-lg font-semibold mb-3 text-on-surface">Events by Category</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-2">
      <% @stats[:categories].each do |category, count| %>
        <%= link_to admin_university_calendar_events_path(category: category, show_all: params[:show_all]),
            class: "m3-card p-3 rounded-xl text-center hover:opacity-80 transition-opacity" do %>
          <div class="text-xl font-bold text-on-surface"><%= count %></div>
          <div class="text-xs text-on-surface-variant"><%= category&.titleize || 'Unknown' %></div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

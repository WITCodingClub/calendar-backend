<div class="container mx-auto px-2 pb-8">
  <h1 class="text-3xl font-bold mb-6">Google Calendars</h1>

  <div class="glass-card shadow-lg rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-white/50">
          <tr>
            <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Calendar ID</th>
            <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
            <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Updated</th>
            <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white/30 divide-y divide-gray-200">
          <% @calendars.each do |calendar| %>
            <tr class="hover:bg-white/50">
              <td class="px-3 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-500 font-mono" title="<%= calendar.google_calendar_id %>">
                  <%= truncate(calendar.google_calendar_id, length: 40) %>
                </div>
              </td>
              <td class="px-3 py-4 whitespace-nowrap">
                <% if calendar.user %>
                  <div class="text-sm text-gray-900"><%= link_to calendar.user.email, admin_user_path(calendar.user), class: "text-[#d13732] hover:underline" %></div>
                  <div class="text-xs text-gray-500"><%= calendar.oauth_credential&.email %></div>
                <% else %>
                  <div class="text-sm text-gray-400">No user</div>
                <% end %>
              </td>
              <td class="px-3 py-4 whitespace-nowrap">
                <% last_updated = calendar.max_event_updated_at || calendar.updated_at %>
                <% if last_updated %>
                  <div class="text-sm text-gray-900"><%= time_ago_in_words(last_updated) %> ago</div>
                  <div class="text-xs text-gray-500"><%= last_updated.strftime("%Y-%m-%d %H:%M") %></div>
                <% else %>
                  <div class="text-sm text-gray-400">Never</div>
                <% end %>
              </td>
              <td class="px-3 py-4 whitespace-nowrap text-sm font-medium">
                <% if policy(calendar).destroy? %>
                  <%= button_to "Delete",
                      admin_calendar_path(calendar.id),
                      method: :delete,
                      data: { turbo_confirm: "⚠️ Permanently delete calendar for #{calendar.user&.email}? This will delete all associated events and cannot be undone." },
                      class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer" %>
                <% else %>
                  <span class="text-gray-400">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @calendars.respond_to?(:total_pages) %>
      <div class="px-6 py-4 border-t border-gray-200 bg-white/40">
        <%= paginate @calendars %>
      </div>
    <% end %>
  </div>
</div>

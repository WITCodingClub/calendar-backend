<div class="container mx-auto px-2 pb-8">
  <h1 class="text-3xl font-bold mb-6 text-on-surface">Google Calendars</h1>

  <div class="m3-card shadow-sm rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-outline-variant">
        <thead class="bg-surface-container-high">
          <tr>
            <th class="px-3 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Calendar ID</th>
            <th class="px-3 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">User</th>
            <th class="px-3 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Last Updated</th>
            <th class="px-3 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
          <% @calendars.each do |calendar| %>
            <tr class="hover:bg-surface-container">
              <td class="px-3 py-4 whitespace-nowrap">
                <div class="text-sm text-on-surface-variant font-mono" title="<%= calendar.google_calendar_id %>">
                  <%= truncate(calendar.google_calendar_id, length: 40) %>
                </div>
              </td>
              <td class="px-3 py-4 whitespace-nowrap">
                <% if calendar.user %>
                  <div class="text-sm text-on-surface"><%= link_to calendar.user.email, admin_user_path(calendar.user), class: "text-primary hover:underline" %></div>
                  <div class="text-xs text-on-surface-variant"><%= calendar.oauth_credential&.email %></div>
                <% else %>
                  <div class="text-sm text-on-surface-variant">No user</div>
                <% end %>
              </td>
              <td class="px-3 py-4 whitespace-nowrap">
                <% last_updated = calendar.max_event_updated_at || calendar.updated_at %>
                <% if last_updated %>
                  <div class="text-sm text-on-surface"><%= time_ago_in_words(last_updated) %> ago</div>
                  <div class="text-xs text-on-surface-variant"><%= last_updated.strftime("%Y-%m-%d %H:%M") %></div>
                <% else %>
                  <div class="text-sm text-on-surface-variant">Never</div>
                <% end %>
              </td>
              <td class="px-3 py-4 whitespace-nowrap text-sm font-medium">
                <% if policy(calendar).destroy? %>
                  <%= button_to "Delete",
                      admin_calendar_path(calendar.id),
                      method: :delete,
                      data: { turbo_confirm: "⚠️ Permanently delete calendar for #{calendar.user&.email}? This will delete all associated events and cannot be undone." },
                      class: "text-on-error-container hover:opacity-80 bg-transparent border-0 p-0 cursor-pointer" %>
                <% else %>
                  <span class="text-on-surface-variant">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @calendars.respond_to?(:total_pages) %>
      <div class="px-6 py-4 border-t border-outline-variant bg-surface-container-low">
        <%= paginate @calendars %>
      </div>
    <% end %>
  </div>
</div>

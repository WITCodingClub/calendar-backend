<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-on-surface">Admin Dashboard</h1>
</div>

<div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8 gap-3 mb-8">
  <%= render "shared/stat_card", title: "Users",           count: @users_count,            path: admin_users_path %>
  <%= render "shared/stat_card", title: "Courses",         count: @courses_count,          path: admin_courses_path %>
  <%= render "shared/stat_card", title: "Faculty",         count: @faculties_count,        path: admin_faculties_path %>
  <%= render "shared/stat_card", title: "Terms",           count: @terms_count,            path: admin_terms_path %>
  <%= render "shared/stat_card", title: "Google Cals",     count: @google_calendars_count, path: admin_calendars_path %>
  <%= render "shared/stat_card", title: "RMP Ratings",     count: @rmp_ratings_count,      path: admin_rmp_ratings_path %>
  <%= render "shared/stat_card", title: "Finals",          count: @finals_schedules_count, path: admin_finals_schedules_path %>
  <%= render "shared/stat_card", title: "Uni Events",      count: @university_events_count, path: admin_university_calendar_events_path %>
</div>

<div class="m3-card">
  <div class="px-4 py-4 border-b border-outline-variant">
    <h3 class="text-sm font-semibold text-on-surface-variant uppercase tracking-wide">Quick Actions</h3>
  </div>
  <div class="p-2">
    <%= link_to admin_users_path, class: "m3-list-item" do %>
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      Manage Users
    <% end %>
    <%= link_to admin_calendars_path, class: "m3-list-item" do %>
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      Manage Calendars
    <% end %>
    <%= link_to missing_rmp_ids_admin_faculties_path, class: "m3-list-item" do %>
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
      Fill Missing RMP IDs
      <% if @missing_rmp_ids_count&.> 0 %>
        <span class="ml-auto m3-badge-error"><%= @missing_rmp_ids_count %></span>
      <% end %>
    <% end %>
    <% if policy(:course_catalog).index? %>
      <%= link_to admin_course_catalog_path, class: "m3-list-item" do %>
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Fetch Course Catalog
      <% end %>
    <% end %>
  </div>
</div>

<div class="container mx-auto px-2 pb-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @term.name %></h1>
      <p class="text-gray-600 text-sm"><%= @term.uid %></p>
    </div>
    <%= link_to "Back to Terms", admin_terms_path, class: "glass-button px-4 py-2 rounded text-sm cursor-pointer inline-block" %>
  </div>

  <div>
    <h2 class="text-xl font-semibold mb-4">Courses (<%= @term.courses.count %>)</h2>
    <% if @courses.any? %>
      <div class="glass-card shadow-lg rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-white/50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Course ID</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Name</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Instructor</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Location</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white/30">
              <% @courses.each do |course| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= course.crn %></td>
                  <td class="px-6 py-4">
                    <div class="text-sm text-gray-900"><%= course.title %></div>
                    <div class="text-xs text-gray-600"><%= course.section_number %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                    <% if course.faculties.any? %>
                      <%= safe_join(course.faculties.map { |f| link_to f.full_name, admin_faculty_path(f), class: "text-[#d13732] hover:underline" }, ", ") %>
                    <% else %>
                      TBA
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                    <%= course.meeting_times.map { |mt| mt.building_room }.compact.uniq.join(", ").presence || "TBA" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <% if @courses.respond_to?(:total_pages) %>
          <div class="px-6 py-4 border-t border-gray-200 bg-white/40">
            <%= paginate @courses %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-600">No courses in this term.</p>
    <% end %>
  </div>
</div>

<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Admin", admin_root_path, class: "text-sm font-medium text-primary hover:underline" %>
  </div>

  <h1 class="text-2xl font-bold mb-2 text-on-surface">Course Catalog Import</h1>
  <p class="text-on-surface-variant mb-6">Import course data from LeopardWeb for each term. Terms marked as "API only" need to be provisioned first.</p>

  <%= turbo_frame_tag "import-statuses",
      data: { controller: "auto-refresh", "auto-refresh-interval-value": 5000, "auto-refresh-url-value": request.path } do %>
    <div class="m3-card shadow-sm rounded-xl overflow-hidden">
      <table class="min-w-full divide-y divide-outline-variant">
        <thead class="bg-surface-container-high">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Term</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Term Code</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Source</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Import Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-on-surface-variant uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
          <% @combined_terms.each do |term_data| %>
            <tr class="hover:bg-surface-container">
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="font-medium text-on-surface"><%= term_data[:description] %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <code class="text-sm bg-surface-container-high px-2 py-1 rounded"><%= term_data[:uid] %></code>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if term_data[:in_database] && term_data[:from_api] %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-tertiary-container text-on-tertiary-container">In DB + API</span>
                <% elsif term_data[:in_database] %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-tertiary-container text-on-tertiary-container">In DB only</span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary-container text-on-secondary-container">API only (not in DB)</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if term_data[:db_term]&.catalog_importing? %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-container text-on-primary-container">
                    <svg class="animate-spin h-3 w-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    Importing…
                  </span>
                <% elsif term_data[:db_term]&.catalog_import_failed? %>
                  <% job_id = term_data[:db_term].catalog_import_job_id %>
                  <% mc_path = job_id ? admin_mission_control_jobs.application_job_path("calendar", job_id, anchor: "error") : admin_mission_control_jobs.root_path %>
                  <%= link_to mc_path, class: "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-error-container text-on-error-container hover:underline" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    Failed
                  <% end %>
                <% elsif term_data[:db_term]&.catalog_imported? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-tertiary-container text-on-tertiary-container">
                    Imported <%= time_ago_in_words(term_data[:db_term].catalog_imported_at) %> ago
                  </span>
                <% elsif term_data[:in_database] %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-container-high text-on-surface-variant">Not imported</span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface-container-high text-on-surface-variant">—</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if term_data[:in_database] %>
                  <% importing = term_data[:db_term]&.catalog_importing? %>
                  <%= button_to importing ? "Importing…" : (term_data[:db_term]&.catalog_imported? ? "Re-import" : "Import"),
                      admin_course_catalog_import_path(term_uid: term_data[:uid]),
                      method: :post,
                      disabled: importing,
                      class: "m3-btn-outlined px-4 py-2 rounded text-sm #{"opacity-50 cursor-not-allowed" if importing}",
                      data: importing ? {} : { turbo_confirm: "Import courses for #{term_data[:description]}?" } %>
                <% else %>
                  <%= button_to "Provision",
                      admin_course_catalog_provision_path(term_uid: term_data[:uid], description: term_data[:description]),
                      method: :post,
                      class: "px-4 py-2 rounded text-sm bg-yellow-500 hover:bg-yellow-600 text-white",
                      data: { turbo_confirm: "Create term #{term_data[:description]} in database?" } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div class="mt-6 p-4 rounded-xl bg-tertiary-container border border-outline-variant">
    <p class="text-sm text-on-tertiary-container">
      <strong>Note:</strong> Course imports run in the background and may take a few minutes.
      Check <%= link_to "Mission Control", admin_mission_control_jobs_path, class: "underline font-medium" %> for job status.
    </p>
  </div>
</div>

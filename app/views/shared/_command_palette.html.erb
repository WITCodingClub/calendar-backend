<div data-controller="command-palette"
     data-command-palette-open-class="opacity-100 pointer-events-auto"
     data-command-palette-closed-class="opacity-0 pointer-events-none">

  <!-- Backdrop -->
  <div class="fixed inset-0 z-40 bg-scrim/40 opacity-0 pointer-events-none transition-opacity duration-150"
       data-command-palette-target="backdrop"
       data-action="click->command-palette#close">
  </div>

  <!-- Panel -->
  <div class="fixed inset-x-0 top-20 z-50 mx-auto max-w-xl px-4 opacity-0 pointer-events-none transition-all duration-150"
       data-command-palette-target="panel">
    <div class="m3-card rounded-xl overflow-hidden shadow-2xl">
      <!-- Search input -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-outline-variant">
        <svg class="w-5 h-5 text-on-surface-variant flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text"
               placeholder="Search admin..."
               class="flex-1 bg-transparent text-on-surface placeholder-on-surface-variant outline-none text-sm"
               data-command-palette-target="input"
               data-action="input->command-palette#filter keydown->command-palette#keydown">
        <kbd class="text-xs text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded border border-outline-variant">ESC</kbd>
      </div>

      <!-- Results -->
      <div class="max-h-80 overflow-y-auto py-2" data-command-palette-target="results">
        <% Admin::NavigationRegistry.items_for_user(current_user).each do |item| %>
          <% item_path = item[:path].is_a?(Symbol) ? send(item[:path]) : item[:path] rescue '#' %>
          <a href="<%= item_path %>"
             class="command-palette-item flex items-center gap-3 px-4 py-2.5 hover:bg-surface-container-high cursor-pointer transition-colors"
             data-label="<%= item[:title].downcase %>">
            <div class="w-7 h-7 flex items-center justify-center rounded-md bg-primary-container text-on-primary-container text-xs font-bold flex-shrink-0">
              <%= item[:title][0] %>
            </div>
            <div>
              <div class="text-sm font-medium text-on-surface"><%= item[:title] %></div>
              <% if item[:description] %>
                <div class="text-xs text-on-surface-variant"><%= item[:description] %></div>
              <% end %>
            </div>
          </a>
        <% end %>
      </div>

      <div class="px-4 py-2 border-t border-outline-variant flex items-center gap-4 text-xs text-on-surface-variant">
        <span><kbd class="bg-surface-container-high px-1 rounded border border-outline-variant">↑↓</kbd> Navigate</span>
        <span><kbd class="bg-surface-container-high px-1 rounded border border-outline-variant">↵</kbd> Open</span>
        <span><kbd class="bg-surface-container-high px-1 rounded border border-outline-variant">ESC</kbd> Close</span>
      </div>
    </div>
  </div>
</div>

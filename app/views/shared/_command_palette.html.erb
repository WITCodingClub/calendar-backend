<div data-controller="command-palette"
     data-command-palette-open-class="opacity-100 pointer-events-auto"
     data-command-palette-closed-class="opacity-0 pointer-events-none">

  <!-- Backdrop -->
  <div class="fixed inset-0 z-40 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-150"
       data-command-palette-target="backdrop"
       data-action="click->command-palette#close">
  </div>

  <!-- Panel -->
  <div class="fixed inset-x-0 top-20 z-50 mx-auto max-w-xl px-4 opacity-0 pointer-events-none transition-all duration-150"
       data-command-palette-target="panel">
    <div class="glass-card rounded-xl overflow-hidden shadow-2xl">
      <!-- Search input -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200/60">
        <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text"
               placeholder="Search admin..."
               class="flex-1 bg-transparent text-gray-900 placeholder-gray-400 outline-none text-sm"
               data-command-palette-target="input"
               data-action="input->command-palette#filter keydown->command-palette#keydown">
        <kbd class="text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded border border-gray-200">ESC</kbd>
      </div>

      <!-- Results -->
      <div class="max-h-80 overflow-y-auto py-2" data-command-palette-target="results">
        <% Admin::NavigationRegistry.all_items.each do |item| %>
          <a href="<%= item[:path] rescue '#' %>"
             class="command-palette-item flex items-center gap-3 px-4 py-2.5 hover:bg-[#d13732]/5 cursor-pointer transition-colors"
             data-label="<%= item[:label].downcase %>">
            <div class="w-7 h-7 flex items-center justify-center rounded-md bg-[#d13732]/10 text-[#d13732] text-xs font-bold flex-shrink-0">
              <%= item[:label][0] %>
            </div>
            <div>
              <div class="text-sm font-medium text-gray-900"><%= item[:label] %></div>
              <% if item[:category] %>
                <div class="text-xs text-gray-400"><%= item[:category] %></div>
              <% end %>
            </div>
          </a>
        <% end %>
      </div>

      <div class="px-4 py-2 border-t border-gray-200/60 flex items-center gap-4 text-xs text-gray-400">
        <span><kbd class="bg-gray-100 px-1 rounded border border-gray-200">↑↓</kbd> Navigate</span>
        <span><kbd class="bg-gray-100 px-1 rounded border border-gray-200">↵</kbd> Open</span>
        <span><kbd class="bg-gray-100 px-1 rounded border border-gray-200">ESC</kbd> Close</span>
      </div>
    </div>
  </div>
</div>

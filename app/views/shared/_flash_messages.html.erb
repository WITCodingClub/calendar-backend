<div id="flash-messages" class="fixed top-4 right-4 z-50 space-y-2 max-w-sm w-full pointer-events-none">
  <% flash.each do |type, message| %>
    <%
      bg_class = case type.to_s
      when "notice", "success" then "bg-primary-container border-primary text-on-primary-container"
      when "alert", "error", "danger" then "bg-error-container border-error text-on-error-container"
      when "warning" then "bg-secondary-container border-secondary text-on-secondary-container"
      else "bg-tertiary-container border-tertiary text-on-tertiary-container"
      end
    %>
    <div class="pointer-events-auto flex items-start gap-3 px-4 py-3 rounded-xl border shadow-lg <%= bg_class %>"
         data-controller="flash-message"
         data-flash-message-timeout-value="5000">
      <p class="text-sm flex-1"><%= message %></p>
      <button type="button"
              class="flex-shrink-0 text-current opacity-60 hover:opacity-100"
              data-action="click->flash-message#dismiss">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>

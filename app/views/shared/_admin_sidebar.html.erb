<% categories = Admin::NavigationRegistry.categories_for(current_user) %>

<!-- Desktop sidebar (fixed) -->
<aside class="hidden lg:flex flex-col fixed inset-y-0 left-0 w-64 z-30 border-r border-outline-variant bg-surface-container"
       data-controller="admin-sidebar">

  <!-- Logo -->
  <div class="flex items-center gap-3 px-5 py-4 border-b border-outline-variant">
    <div class="w-8 h-8 rounded-lg bg-primary-container flex items-center justify-center">
      <svg class="w-5 h-5 text-on-primary-container" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
    </div>
    <div>
      <p class="text-sm font-bold text-on-surface">WIT Calendar</p>
      <p class="text-xs text-on-surface-variant">Admin</p>
    </div>
  </div>

  <!-- Dashboard link (returns to user dashboard) -->
  <div class="px-3 pt-3">
    <%= link_to dashboard_root_path,
        class: "flex items-center gap-2 px-3 py-2 rounded-2xl text-sm font-medium text-on-surface-variant hover:bg-surface-container-high" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Dashboard
    <% end %>
  </div>

  <!-- Nav categories -->
  <nav class="flex-1 overflow-y-auto px-3 pb-4 space-y-1 mt-1">
    <% categories.each do |category| %>
      <div data-controller="sidebar-category">
        <button type="button"
                class="w-full flex items-center justify-between px-3 py-1.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider hover:text-on-surface cursor-pointer"
                data-action="click->sidebar-category#toggle">
          <span><%= category[:title] %></span>
          <svg class="w-3.5 h-3.5 transition-transform" data-sidebar-category-target="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div data-sidebar-category-target="items">
          <% category[:items].each do |item| %>
            <% resolved_path = item[:path].is_a?(Symbol) ? send(item[:path]) : item[:path] %>
            <%= link_to item[:title], resolved_path,
                class: "flex items-center gap-2 px-3 py-2 rounded-2xl text-sm #{request.path.start_with?(resolved_path.to_s) ? 'bg-secondary-container text-on-secondary-container font-medium' : 'text-on-surface-variant hover:bg-surface-container-high'}" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </nav>
</aside>

<!-- Mobile sidebar overlay -->
<div class="lg:hidden fixed inset-0 z-40 hidden"
     data-admin-sidebar-target="overlay"
     data-action="click->admin-sidebar#close">
  <div class="absolute inset-0 bg-scrim/40"></div>
  <aside class="relative w-64 h-full flex flex-col border-r border-outline-variant bg-surface-container-high">
    <div class="flex items-center justify-between px-5 py-4 border-b border-outline-variant">
      <p class="text-sm font-bold text-on-surface">WIT Calendar Admin</p>
      <button type="button" data-action="click->admin-sidebar#close" class="text-on-surface-variant hover:text-on-surface">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <nav class="flex-1 overflow-y-auto px-3 py-3 space-y-1">
      <%= link_to "Dashboard", dashboard_root_path, class: "block px-3 py-2 rounded-2xl text-sm text-on-surface-variant hover:bg-surface-container" %>
      <% categories.each do |category| %>
        <div class="pt-2">
          <p class="px-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1"><%= category[:title] %></p>
          <% category[:items].each do |item| %>
            <% resolved_path = item[:path].is_a?(Symbol) ? send(item[:path]) : item[:path] %>
            <%= link_to item[:title], resolved_path, class: "block px-3 py-2 rounded-2xl text-sm text-on-surface-variant hover:bg-surface-container" %>
          <% end %>
        </div>
      <% end %>
    </nav>
  </aside>
</div>
